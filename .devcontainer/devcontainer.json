{
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  // DeckLink device passthrough and host library access
  "runArgs": [
    "--device=/dev/blackmagic",
    "--userns=keep-id",
    "--security-opt=label=disable"
  ],

  "containerEnv": {
    "SSH_AUTH_SOCK": "/tmp/ssh-agent.sock",
    "DECKLINK_SDK_DIR": "/workspaces/pydecklink/vendor/Blackmagic DeckLink SDK 15.3/Linux/include"
  },

  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false,
      "installOhMyZsh": false,
      "installOhMyZshConfig": false,
      "upgradePackages": false,
      "username": "ubuntu",
      "userUid": "automatic",
      "userGid": "automatic"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/meaningful-ooo/devcontainer-features/fish:2": {}
  },

  "mounts": [
    // Bind-mount Desktop Video SDK libs and private runtime from host.
    // lib/ has libDeckLinkAPI.so (RUNPATH: $ORIGIN/blackmagic/DesktopVideo)
    //   and symlinks at lib/blackmagic/DesktopVideo/ -> bin/ for RUNPATH resolution.
    // bin/ has binaries + private libc++/libc++abi (RUNPATH: $ORIGIN).
    // Both must be at host paths so the symlinks resolve.
    "source=/var/lib/blackmagic/lib,target=/var/lib/blackmagic/lib,type=bind,readonly",
    "source=/var/lib/blackmagic/bin,target=/var/lib/blackmagic/bin,type=bind,readonly",
    // Bind mount Claude auth and settings from host (read-only credentials, read-write settings)
    "source=${localEnv:HOME}/.claude/.credentials.json,target=/home/ubuntu/.claude/.credentials.json,type=bind",
    "source=${localEnv:HOME}/.claude/settings.json,target=/home/ubuntu/.claude/settings.json,type=bind",
    "source=${localEnv:HOME}/.claude/CLAUDE.md,target=/home/ubuntu/.claude/CLAUDE.md,type=bind",
    "source=${localEnv:HOME}/.claude/commands,target=/home/ubuntu/.claude/commands,type=bind",
    // SSH agent forwarding for git signing/commits. The source path is
    // a fixed host-side indirection managed by .devcontainer/ensure-mounts.sh:
    // a symlink to the real $SSH_AUTH_SOCK when an agent exists, or a
    // placeholder file when it doesn't. This lets initializeCommand handle
    // the fallback without needing to re-export SSH_AUTH_SOCK into the
    // parent devcontainer CLI's env.
    "source=/tmp/ssh-agent-pydecklink-${localEnv:USER}.sock,target=/tmp/ssh-agent.sock,type=bind",
    // Git config for commit signing and user identity
    "source=${localEnv:HOME}/.gitconfig,target=/home/ubuntu/.gitconfig,type=bind,readonly",
    // GitHub CLI auth (uses host login, read-only to avoid token conflicts)
    "source=${localEnv:HOME}/.config/gh,target=/home/ubuntu/.config/gh,type=bind,readonly"
  ],

  // Stub host paths so bind mounts don't fail when optional config
  // (Claude auth, gh login, SSH agent) isn't present on the host.
  "initializeCommand": "bash .devcontainer/ensure-mounts.sh",

  // Rebuild ld.so cache so the linker finds bind-mounted Desktop Video libs.
  "postCreateCommand": "sudo ldconfig",

  "remoteUser": "ubuntu",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-vscode.cmake-tools",
        "ms-vscode.cpptools"
      ]
    }
  }
}
