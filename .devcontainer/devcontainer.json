{
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  // AJA NTV2 device passthrough
  "runArgs": [
    "--device=/dev/ajantv20",
    "--userns=keep-id",
    "--security-opt=label=disable",
    "--ulimit", "memlock=-1",
    "--ulimit", "stack=67108864",
    "--shm-size", "1g"
  ],

  "containerEnv": {
    "SSH_AUTH_SOCK": "/tmp/ssh-agent.sock"
  },

  "mounts": [
    // Named volume for container-local Claude state (history, cache, etc.)
    "source=claude-config-${devcontainerId},target=/home/dev/.claude,type=volume",
    // Bind mount Claude auth and settings from host (read-only credentials, read-write settings)
    "source=${localEnv:HOME}/.claude/.credentials.json,target=/home/dev/.claude/.credentials.json,type=bind",
    "source=${localEnv:HOME}/.claude/settings.json,target=/home/dev/.claude/settings.json,type=bind",
    "source=${localEnv:HOME}/.claude/CLAUDE.md,target=/home/dev/.claude/CLAUDE.md,type=bind",
    "source=${localEnv:HOME}/.claude/ORCHESTRATOR.md,target=/home/dev/.claude/ORCHESTRATOR.md,type=bind",
    "source=${localEnv:HOME}/.claude/commands,target=/home/dev/.claude/commands,type=bind",
    // SSH agent forwarding for git signing/commits
    "source=${localEnv:SSH_AUTH_SOCK},target=/tmp/ssh-agent.sock,type=bind",
    // Git config for commit signing and user identity
    "source=${localEnv:HOME}/.gitconfig,target=/home/dev/.gitconfig,type=bind,readonly",
    // GitHub CLI auth (uses host login, read-only to avoid token conflicts)
    "source=${localEnv:HOME}/.config/gh,target=/home/dev/.config/gh,type=bind,readonly"
  ],

  "remoteEnv": {
    "UV_PROJECT_ENVIRONMENT": ".venv-dev",
    "VIRTUAL_ENV": "${containerWorkspaceFolder}/.venv-dev"
  },

  // Ensure the named volume for .claude is writable by the dev user.
  // Podman creates named volumes owned by root; the bind-mounted files
  // on top work fine, but Claude needs to create subdirs (plans/, session-env/).
  "postCreateCommand": "sudo chown dev:dev /home/dev/.claude",

  "remoteUser": "dev",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-vscode.cmake-tools",
        "ms-vscode.cpptools"
      ]
    }
  }
}
